# Server env (Express, Phase 4+). Copy to server/.env and fill in.
PORT=4000
CLIENT_ORIGIN=http://localhost:5173

# Supabase — server uses the SECRET service-role key to finalize orders
# (bypasses RLS). Keep this out of the browser and out of git.
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_URL=https://YOUR_PROJECT_URL.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Stripe (Phase 5 — leave blank for now)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
