# Client env (Vite). Copy to client/.env and fill in.
# Only the PUBLIC anon key belongs here — it is safe to ship to the browser
# because Row Level Security protects the data. Never put the service-role key here.
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Base URL of the Express API (Phase 4+).
VITE_API_URL=http://localhost:4000
