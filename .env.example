# Root env — used by the DummyJSON seed script (npm run seed).
# Copy to .env and fill with values from your Supabase project
# (Project Settings -> API). The service-role key is SECRET — never expose it
# to the browser or commit the real .env.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
